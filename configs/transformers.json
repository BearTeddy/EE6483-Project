{
  "models": [
    "bert-base-uncased",
    "roberta-base"
  ],
  "settings": {
    "test_size": 0.2,
    "random_state": 42,
    "max_length": 256,
    "train_batch_size": 16,
    "eval_batch_size": 32,
    "learning_rate": 2e-05,
    "weight_decay": 0.01,
    "num_train_epochs": 3,
    "warmup_ratio": 0.1
  }
}
